{
  "name": "robloquake",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      }
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$properties": {
        "LoadCharacterAppearance": false,
        "CharacterWalkSpeed": 0
      },
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "Client": {
          "$path": "src/client"
        }
      }
    },
    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Brightness": 0,
        "GlobalShadows": false,
        "Ambient": [
          1,
          1,
          1
        ],
        "OutdoorAmbient": [
          1,
          1,
          1
        ],
        "EnvironmentDiffuseScale": 0,
        "EnvironmentSpecularScale": 0
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "Gravity": 0
      }
    }
  }
}