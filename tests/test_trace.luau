--!strict
-- Compares the Luau hull collision port against ground truth generated by
-- tools/trace_truth.c (verbatim WinQuake world.c code compiled natively).
-- Regenerate the fixture with:
--   cc -O2 -o /tmp/trace_truth tools/trace_truth.c && /tmp/trace_truth > tests/fixtures/trace_truth.txt

local fs = require("@lune/fs")

local t = require("./testutil")
local vfs = require("../src/shared/engine/common/vfs")
local bsp = require("../src/shared/engine/bsp/bsp")
local world = require("../src/shared/engine/server/world")

local fsys = t.gameFs()
local buf = vfs.loadFile(fsys, "maps/e1m1.bsp")
assert(buf)
local models = bsp.load("maps/e1m1.bsp", buf)
local wm = models[1]

local fixture = fs.readFile("tests/fixtures/trace_truth.txt")
local lines = fixture:split("\n")

local function nums(line: string): { number }
	local out = {}
	for w in line:gmatch("[^ ]+") do
		table.insert(out, tonumber(w) :: number)
	end
	return out
end

local li = 1
t.eq(lines[li], "POINTS", "fixture header")
li += 1

-- point contents: "<c0> <c1> <c2> <x> <y> <z>"
local pointCount = 0
while lines[li] ~= "TRACES" do
	local v = nums(lines[li])
	local p = vector.create(v[4], v[5], v[6])
	for h = 1, 3 do
		local hull = wm.hulls[h]
		local got = world.hullPointContents(hull, hull.firstclipnode, p)
		t.eq(got, v[h], `point {pointCount} hull {h - 1} contents`)
	end
	pointCount += 1
	li += 1
end
t.eq(pointCount, 200, "point count")
li += 1 -- skip TRACES

-- traces: 3 hull lines then a SEG line
local traceCount = 0
local mismatches = 0
while li <= #lines and lines[li] ~= "" do
	local hullLines = { nums(lines[li]), nums(lines[li + 1]), nums(lines[li + 2]) }
	local seg = lines[li + 3]
	assert(seg:sub(1, 4) == "SEG ", "expected SEG line, got: " .. seg)
	local sv = nums(seg:sub(5))
	local p1 = vector.create(sv[1], sv[2], sv[3])
	local p2 = vector.create(sv[4], sv[5], sv[6])

	for h = 1, 3 do
		local want = hullLines[h]
		local hull = wm.hulls[h]
		local trace: world.Trace = {
			allsolid = true,
			startsolid = false,
			inopen = false,
			inwater = false,
			fraction = 1,
			endpos = p2,
			planeNormal = vector.zero,
			planeDist = 0,
			ent = nil,
		}
		world.recursiveHullCheck(hull, hull.firstclipnode, 0, 1, p1, p2, trace)

		local ok = (trace.allsolid == (want[1] == 1))
			and (trace.startsolid == (want[2] == 1))
			and (trace.inopen == (want[3] == 1))
			and (trace.inwater == (want[4] == 1))
			and math.abs(trace.fraction - want[5]) < 1e-4
			and math.abs(trace.endpos.x - want[6]) < 0.01
			and math.abs(trace.endpos.y - want[7]) < 0.01
			and math.abs(trace.endpos.z - want[8]) < 0.01
			and math.abs(trace.planeNormal.x - want[9]) < 1e-5
			and math.abs(trace.planeNormal.y - want[10]) < 1e-5
			and math.abs(trace.planeNormal.z - want[11]) < 1e-5
			and math.abs(trace.planeDist - want[12]) < 0.01
		if not ok then
			mismatches += 1
			if mismatches <= 5 then
				print(
					`trace {traceCount} hull {h - 1}: got as={trace.allsolid} ss={trace.startsolid} io={trace.inopen} iw={trace.inwater} f={trace.fraction} end=({trace.endpos}) n=({trace.planeNormal}) d={trace.planeDist}`
				)
				print(`  want {lines[li + h - 1]}  seg {seg}`)
			end
		end
		t.check(ok, `trace {traceCount} hull {h - 1}`)
	end

	traceCount += 1
	li += 4
end
t.eq(traceCount, 300, "trace count")

t.finish("test_trace")
